generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CompanyStatus {
  PENDING
  APPROVED
  ACTIVE
  REJECTED
  SUSPENDED
  BANKRUPT
  CLOSED
}

enum TransferType {
  ISSUANCE_TO_TREASURY
  TREASURY_TO_BROKER
  BROKER_TO_USER
  USER_TRADE
  ADJUSTMENT
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
  CANCELED
}

enum CompanyOperationType {
  INITIAL_OFFER_BUY
  ADMIN_APPROVE
  ADMIN_REJECT
  ADMIN_SUSPEND
  MARKET_ORDER_CREATE
  MARKET_ORDER_CANCEL
  MARKET_TRADE_EXECUTED
  PROJECT_BOOST
}

enum CompanyBoostSource {
  PERSONAL_WALLET
  PROJECT_REVENUE
  ADMIN_ADJUSTMENT
}

enum MarketOrderType {
  BUY
  SELL
}

enum MarketOrderMode {
  LIMIT
  MARKET
}

enum MarketOrderStatus {
  OPEN
  PARTIALLY_FILLED
  FILLED
  CANCELED
  REJECTED
}

enum FeeSourceType {
  INITIAL_OFFER_BUY
  MARKET_TRADE_BUY_FEE
  MARKET_TRADE_SELL_FEE
  MARKET_TRADE_TOTAL_FEE
}

model User {
  id           String           @id @default(cuid())
  name         String
  email        String           @unique
  passwordHash String
  isBlocked    Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  wallet       Wallet?
  roles        UserRole[]
  companies    Company[]        @relation("CompanyFounder")
  logs         AdminLog[]
  transfersOut CoinTransfer[]   @relation("transfer_sender")
  transfersIn  CoinTransfer[]   @relation("transfer_receiver")
  holdings     CompanyHolding[]
  operations   CompanyOperation[]
  marketOrders MarketOrder[]
  buyTrades    Trade[]            @relation("trade_buyer")
  sellTrades   Trade[]            @relation("trade_seller")
  paidFeeDistributions FeeDistribution[] @relation("fee_distribution_payer")
  withdrawalRequests WithdrawalRequest[] @relation("withdrawal_request_user")
  reviewedWithdrawalRequests WithdrawalRequest[] @relation("withdrawal_request_reviewer")
  boostInjections CompanyBoostInjection[]
}

model Role {
  id          String           @id @default(cuid())
  key         String           @unique
  name        String
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id    String           @id @default(cuid())
  key   String           @unique
  roles RolePermission[]
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model Wallet {
  id               String   @id @default(cuid())
  userId           String   @unique
  availableBalance Decimal  @default(0) @db.Decimal(18, 2)
  lockedBalance    Decimal  @default(0) @db.Decimal(18, 2)
  pendingWithdrawalBalance Decimal @default(0) @db.Decimal(18, 2)
  investedValue    Decimal  @default(0) @db.Decimal(18, 2)
  fictitiousProfit Decimal  @default(0) @db.Decimal(18, 2)
  user             User     @relation(fields: [userId], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model TreasuryAccount {
  id        String   @id @default(cuid())
  balance   Decimal  @default(0) @db.Decimal(18, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BrokerAccount {
  id            String   @id @default(cuid())
  userId        String   @unique
  receivedTotal Decimal  @default(0) @db.Decimal(18, 2)
  available     Decimal  @default(0) @db.Decimal(18, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Company {
  id                  String              @id @default(cuid())
  name                String
  ticker              String              @unique
  description         String
  sector              String
  founderUserId       String
  status              CompanyStatus       @default(PENDING)
  totalShares         Int
  circulatingShares   Int                 @default(0)
  ownerSharePercent   Decimal             @db.Decimal(5, 2)
  publicOfferPercent  Decimal             @db.Decimal(5, 2)
  ownerShares         Int                 @default(0)
  publicOfferShares   Int                 @default(0)
  availableOfferShares Int                @default(0)
  initialPrice        Decimal             @db.Decimal(24, 8)
  currentPrice        Decimal             @db.Decimal(24, 8)
  buyFeePercent       Decimal             @db.Decimal(5, 2)
  sellFeePercent      Decimal             @db.Decimal(5, 2)
  fictitiousMarketCap Decimal             @db.Decimal(24, 8)
  createdAt           DateTime            @default(now())
  approvedAt          DateTime?
  rejectedAt          DateTime?
  suspendedAt         DateTime?
  founder             User                @relation("CompanyFounder", fields: [founderUserId], references: [id])
  holdings            CompanyHolding[]
  operations          CompanyOperation[]
  initialOffer        CompanyInitialOffer?
  marketOrders        MarketOrder[]
  trades              Trade[]
  revenueAccount      CompanyRevenueAccount?
  feeDistributions    FeeDistribution[]
  boostAccount        CompanyBoostAccount?
  boostInjections     CompanyBoostInjection[]
}

model CompanyHolding {
  id               String   @id @default(cuid())
  userId           String
  companyId        String
  shares           Int      @default(0)
  averageBuyPrice  Decimal  @default(0) @db.Decimal(24, 8)
  estimatedValue   Decimal  @default(0) @db.Decimal(24, 8)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id])
  company          Company  @relation(fields: [companyId], references: [id])

  @@unique([userId, companyId])
}

model CompanyInitialOffer {
  id               String   @id @default(cuid())
  companyId        String   @unique
  totalShares      Int
  availableShares  Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  company          Company  @relation(fields: [companyId], references: [id])
}

model CompanyOperation {
  id            String               @id @default(cuid())
  companyId     String
  userId        String?
  type          CompanyOperationType
  quantity      Int?
  unitPrice     Decimal?             @db.Decimal(24, 8)
  grossAmount   Decimal?             @db.Decimal(18, 2)
  feeAmount     Decimal?             @db.Decimal(18, 2)
  totalAmount   Decimal?             @db.Decimal(18, 2)
  description   String
  createdAt     DateTime             @default(now())
  company       Company              @relation(fields: [companyId], references: [id])
  user          User?                @relation(fields: [userId], references: [id])
  feeDistributions FeeDistribution[]
}

model MarketOrder {
  id              String            @id @default(cuid())
  companyId       String
  userId          String
  type            MarketOrderType
  mode            MarketOrderMode
  quantity        Int
  remainingQuantity Int
  lockedCash      Decimal           @default(0) @db.Decimal(18, 2)
  lockedShares    Int               @default(0)
  limitPrice      Decimal?          @db.Decimal(24, 8)
  slippagePercent Decimal?          @db.Decimal(5, 2)
  status          MarketOrderStatus @default(OPEN)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  executedAt      DateTime?
  canceledAt      DateTime?
  company         Company           @relation(fields: [companyId], references: [id])
  user            User              @relation(fields: [userId], references: [id])
  buyTrades       Trade[]           @relation("trade_buy_order")
  sellTrades      Trade[]           @relation("trade_sell_order")
}

model Trade {
  id            String      @id @default(cuid())
  companyId     String
  buyerId       String
  sellerId      String
  buyOrderId    String?
  sellOrderId   String?
  quantity      Int
  unitPrice     Decimal     @db.Decimal(24, 8)
  grossAmount   Decimal     @db.Decimal(18, 2)
  buyFeeAmount  Decimal     @db.Decimal(18, 2)
  sellFeeAmount Decimal     @db.Decimal(18, 2)
  createdAt     DateTime    @default(now())
  company       Company     @relation(fields: [companyId], references: [id])
  buyer         User        @relation("trade_buyer", fields: [buyerId], references: [id])
  seller        User        @relation("trade_seller", fields: [sellerId], references: [id])
  buyOrder      MarketOrder? @relation("trade_buy_order", fields: [buyOrderId], references: [id])
  sellOrder     MarketOrder? @relation("trade_sell_order", fields: [sellOrderId], references: [id])
  feeDistributions FeeDistribution[]
}


model PlatformAccount {
  id                String   @id @default(cuid())
  balance           Decimal  @default(0) @db.Decimal(18, 2)
  totalReceivedFees Decimal  @default(0) @db.Decimal(18, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model CompanyRevenueAccount {
  id                String   @id @default(cuid())
  companyId         String   @unique
  balance           Decimal  @default(0) @db.Decimal(18, 2)
  totalReceivedFees Decimal  @default(0) @db.Decimal(18, 2)
  totalWithdrawn    Decimal  @default(0) @db.Decimal(18, 2)
  totalUsedForBoost Decimal  @default(0) @db.Decimal(18, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  company           Company  @relation(fields: [companyId], references: [id])
}

model CompanyBoostAccount {
  id               String   @id @default(cuid())
  companyId        String   @unique
  rpcBalance       Decimal  @default(0) @db.Decimal(18, 2)
  totalInjectedRpc Decimal  @default(0) @db.Decimal(18, 2)
  totalUsedRpc     Decimal  @default(0) @db.Decimal(18, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  company          Company  @relation(fields: [companyId], references: [id])
}

model CompanyBoostInjection {
  id              String            @id @default(cuid())
  companyId       String
  userId          String?
  source          CompanyBoostSource
  amountRpc       Decimal           @db.Decimal(18, 2)
  priceBefore     Decimal           @db.Decimal(24, 8)
  priceAfter      Decimal           @db.Decimal(24, 8)
  marketCapBefore Decimal           @db.Decimal(18, 2)
  marketCapAfter  Decimal           @db.Decimal(18, 2)
  reason          String
  createdAt       DateTime          @default(now())
  company         Company           @relation(fields: [companyId], references: [id])
  user            User?             @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([userId])
  @@index([source])
  @@index([createdAt])
}

model FeeDistribution {
  id                   String        @id @default(cuid())
  companyId            String
  tradeId              String?
  operationId          String?
  payerUserId          String?
  sourceType           FeeSourceType
  totalFeeAmount       Decimal       @db.Decimal(18, 2)
  platformAmount       Decimal       @db.Decimal(18, 2)
  companyAmount        Decimal       @db.Decimal(18, 2)
  platformSharePercent Decimal       @db.Decimal(5, 2)
  companySharePercent  Decimal       @db.Decimal(5, 2)
  createdAt            DateTime      @default(now())
  company              Company       @relation(fields: [companyId], references: [id])
  trade                Trade?        @relation(fields: [tradeId], references: [id])
  operation            CompanyOperation? @relation(fields: [operationId], references: [id])
  payerUser            User?         @relation("fee_distribution_payer", fields: [payerUserId], references: [id])

  @@index([companyId, createdAt])
  @@index([tradeId])
  @@index([operationId])
  @@index([payerUserId])
}

model CoinIssuance {
  id            String   @id @default(cuid())
  createdById   String
  amount        Decimal  @db.Decimal(18, 2)
  reason        String
  destination   String
  previousValue Decimal  @db.Decimal(18, 2)
  newValue      Decimal  @db.Decimal(18, 2)
  createdAt     DateTime @default(now())
}

model WithdrawalRequest {
  id           String           @id @default(cuid())
  code         String           @unique
  userId       String
  user         User             @relation("withdrawal_request_user", fields: [userId], references: [id])
  amount       Decimal          @db.Decimal(18, 2)
  status       WithdrawalStatus @default(PENDING)
  userNote     String?
  adminNote    String?
  requestedAt  DateTime         @default(now())
  processingAt DateTime?
  completedAt  DateTime?
  rejectedAt   DateTime?
  canceledAt   DateTime?
  reviewedById String?
  reviewedBy   User?            @relation("withdrawal_request_reviewer", fields: [reviewedById], references: [id])
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([userId])
  @@index([status])
  @@index([code])
  @@index([createdAt])
}

model CoinTransfer {
  id            String       @id @default(cuid())
  type          TransferType
  senderId      String?
  receiverId    String?
  amount        Decimal      @db.Decimal(18, 2)
  reason        String
  previousValue Decimal      @db.Decimal(18, 2)
  newValue      Decimal      @db.Decimal(18, 2)
  createdAt     DateTime     @default(now())
  sender        User?        @relation("transfer_sender", fields: [senderId], references: [id])
  receiver      User?        @relation("transfer_receiver", fields: [receiverId], references: [id])
}

model Transaction {
  id          String   @id @default(cuid())
  walletId    String
  type        String
  amount      Decimal  @db.Decimal(18, 2)
  description String
  createdAt   DateTime @default(now())
}

model AdminLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entity     String
  previous   String?
  current    String?
  reason     String?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])
}
