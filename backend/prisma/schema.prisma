generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CompanyStatus {
  PENDING
  APPROVED
  ACTIVE
  REJECTED
  SUSPENDED
  BANKRUPT
  CLOSED
}

enum TransferType {
  ISSUANCE_TO_TREASURY
  TREASURY_TO_BROKER
  BROKER_TO_USER
  USER_TRADE
  ADJUSTMENT
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
  CANCELED
}

enum CompanyOperationType {
  INITIAL_OFFER_BUY
  ADMIN_APPROVE
  ADMIN_REJECT
  ADMIN_SUSPEND
  MARKET_ORDER_CREATE
  MARKET_ORDER_CANCEL
  MARKET_TRADE_EXECUTED
  PROJECT_BOOST
  PROJECT_BUYBACK_EXECUTION
}

enum ProjectBuybackStatus {
  ACTIVE
  COMPLETED
  CANCELED
  EXPIRED
}

enum CompanyBoostSource {
  PERSONAL_WALLET
  PROJECT_REVENUE
  ADMIN_ADJUSTMENT
}

enum ProjectTokenReservePolicy {
  HOLD_LOCKED
  BURN_FUTURE
  EVENT_REWARD_FUTURE
  CONTROLLED_REOFFER_FUTURE
}

enum MarketOrderType {
  BUY
  SELL
}

enum MarketOrderMode {
  LIMIT
  MARKET
}

enum MarketOrderStatus {
  OPEN
  PARTIALLY_FILLED
  FILLED
  CANCELED
  REJECTED
}

enum FeeSourceType {
  INITIAL_OFFER_BUY
  MARKET_TRADE_BUY_FEE
  MARKET_TRADE_SELL_FEE
  MARKET_TRADE_TOTAL_FEE
}

enum RpcExchangeSide {
  BUY_RPC
  SELL_RPC
}

enum RpcLimitOrderStatus {
  OPEN
  FILLED
  CANCELED
  REJECTED
}

enum CompanyCapitalFlowType {
  OWNER_RPC_CONTRIBUTION
  ADMIN_RPC_ADJUSTMENT
  PROJECT_REVENUE_IN
  PROJECT_REVENUE_OUT
}

enum CompanyCapitalFlowSource {
  OWNER_WALLET
  ADMIN_ADJUSTMENT
  MARKET_FEE
  MANUAL_CORRECTION
}

enum ProjectHolderDistributionStatus {
  DRAFT
  READY
  COMPLETED
  CANCELED
}

enum ProjectHolderDistributionSnapshotStatus {
  PENDING
  PAID
  SKIPPED
}

model User {
  id           String           @id @default(cuid())
  name         String
  email        String           @unique
  characterName String?
  bankAccountNumber String?
  passwordHash String
  isBlocked    Boolean          @default(false)
  failedLoginAttempts Int       @default(0)
  loginLockedUntil DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  wallet       Wallet?
  roles        UserRole[]
  companies    Company[]        @relation("CompanyFounder")
  logs         AdminLog[]
  transfersOut CoinTransfer[]   @relation("transfer_sender")
  transfersIn  CoinTransfer[]   @relation("transfer_receiver")
  holdings     CompanyHolding[]
  operations   CompanyOperation[]
  createdBuybackPrograms ProjectBuybackProgram[]
  createdHolderDistributionPrograms ProjectHolderDistributionProgram[]
  holderDistributionSnapshots ProjectHolderDistributionSnapshot[]
  holderDistributionPayments ProjectHolderDistributionPayment[]
  marketOrders MarketOrder[]
  buyTrades    Trade[]            @relation("trade_buyer")
  sellTrades   Trade[]            @relation("trade_seller")
  buybackExecutionsAsSeller ProjectBuybackExecution[]
  paidFeeDistributions FeeDistribution[] @relation("fee_distribution_payer")
  withdrawalRequests WithdrawalRequest[] @relation("withdrawal_request_user")
  reviewedWithdrawalRequests WithdrawalRequest[] @relation("withdrawal_request_reviewer")
  boostInjections CompanyBoostInjection[]
  capitalFlowEntries CompanyCapitalFlowEntry[]
  rpcExchangeTrades RpcExchangeTrade[]
  rpcLimitOrders RpcLimitOrder[]
  testModeWallet TestModeWallet?
  testModeTrades TestModeTrade[]
  testModeReports TestModeReport[]
}

model Role {
  id          String           @id @default(cuid())
  key         String           @unique
  name        String
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id    String           @id @default(cuid())
  key   String           @unique
  roles RolePermission[]
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model Wallet {
  id                         String   @id @default(cuid())
  userId                     String   @unique
  // Legacy fields (deprecated): manter temporariamente para compatibilidade
  availableBalance           Decimal  @default(0) @db.Decimal(18, 2)
  lockedBalance              Decimal  @default(0) @db.Decimal(18, 2)
  pendingWithdrawalBalance   Decimal  @default(0) @db.Decimal(18, 2)

  fiatAvailableBalance       Decimal  @default(0) @db.Decimal(18, 2)
  fiatLockedBalance          Decimal  @default(0) @db.Decimal(18, 2)
  fiatPendingWithdrawalBalance Decimal @default(0) @db.Decimal(18, 2)

  rpcAvailableBalance        Decimal  @default(0) @db.Decimal(18, 2)
  rpcLockedBalance           Decimal  @default(0) @db.Decimal(18, 2)

  investedValue              Decimal  @default(0) @db.Decimal(18, 2)
  fictitiousProfit           Decimal  @default(0) @db.Decimal(18, 2)
  user                       User     @relation(fields: [userId], references: [id])
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model TreasuryAccount {
  id        String   @id @default(cuid())
  balance   Decimal  @default(0) @db.Decimal(18, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BrokerAccount {
  id            String   @id @default(cuid())
  userId        String   @unique
  receivedTotal Decimal  @default(0) @db.Decimal(18, 2)
  available     Decimal  @default(0) @db.Decimal(18, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Company {
  id                  String              @id @default(cuid())
  name                String
  ticker              String              @unique
  description         String
  sector              String
  founderUserId       String
  status              CompanyStatus       @default(PENDING)
  totalShares         Int
  circulatingShares   Int                 @default(0)
  ownerSharePercent   Decimal             @db.Decimal(5, 2)
  publicOfferPercent  Decimal             @db.Decimal(5, 2)
  ownerShares         Int                 @default(0)
  publicOfferShares   Int                 @default(0)
  availableOfferShares Int                @default(0)
  initialPrice        Decimal             @db.Decimal(24, 8)
  currentPrice        Decimal             @db.Decimal(24, 8)
  buyFeePercent       Decimal             @db.Decimal(5, 2)
  sellFeePercent      Decimal             @db.Decimal(5, 2)
  fictitiousMarketCap Decimal             @db.Decimal(24, 8)
  createdAt           DateTime            @default(now())
  approvedAt          DateTime?
  rejectedAt          DateTime?
  suspendedAt         DateTime?
  founder             User                @relation("CompanyFounder", fields: [founderUserId], references: [id])
  holdings            CompanyHolding[]
  operations          CompanyOperation[]
  initialOffer        CompanyInitialOffer?
  marketOrders        MarketOrder[]
  trades              Trade[]
  revenueAccount      CompanyRevenueAccount?
  feeDistributions    FeeDistribution[]
  boostAccount        CompanyBoostAccount?
  boostInjections     CompanyBoostInjection[]
  capitalFlowEntries  CompanyCapitalFlowEntry[]
  holderDistributionPrograms ProjectHolderDistributionProgram[]
  holderDistributionSnapshots ProjectHolderDistributionSnapshot[]
  holderDistributionPayments ProjectHolderDistributionPayment[]
  buybackPrograms     ProjectBuybackProgram[]
  buybackExecutions   ProjectBuybackExecution[]
  tokenReserve        ProjectTokenReserve?
  tokenReserveEntries ProjectTokenReserveEntry[] @relation("reserve_entry_company")
}


model CompanyHolding {
  id               String   @id @default(cuid())
  userId           String
  companyId        String
  shares           Int      @default(0)
  averageBuyPrice  Decimal  @default(0) @db.Decimal(24, 8)
  estimatedValue   Decimal  @default(0) @db.Decimal(24, 8)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id])
  company          Company  @relation(fields: [companyId], references: [id])

  @@unique([userId, companyId])
}

model CompanyInitialOffer {
  id               String   @id @default(cuid())
  companyId        String   @unique
  totalShares      Int
  availableShares  Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  company          Company  @relation(fields: [companyId], references: [id])
}

model CompanyOperation {
  id            String               @id @default(cuid())
  companyId     String
  userId        String?
  type          CompanyOperationType
  quantity      Int?
  unitPrice     Decimal?             @db.Decimal(24, 8)
  grossAmount   Decimal?             @db.Decimal(18, 2)
  feeAmount     Decimal?             @db.Decimal(18, 2)
  totalAmount   Decimal?             @db.Decimal(18, 2)
  description   String
  createdAt     DateTime             @default(now())
  company       Company              @relation(fields: [companyId], references: [id])
  user          User?                @relation(fields: [userId], references: [id])
  feeDistributions FeeDistribution[]
}


model MarketOrder {
  id              String            @id @default(cuid())
  companyId       String
  userId          String
  type            MarketOrderType
  mode            MarketOrderMode
  quantity        Int
  remainingQuantity Int
  lockedCash      Decimal           @default(0) @db.Decimal(18, 2)
  lockedShares    Int               @default(0)
  limitPrice      Decimal?          @db.Decimal(24, 8)
  slippagePercent Decimal?          @db.Decimal(5, 2)
  status          MarketOrderStatus @default(OPEN)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  executedAt      DateTime?
  canceledAt      DateTime?
  company         Company           @relation(fields: [companyId], references: [id])
  user            User              @relation(fields: [userId], references: [id])
  buyTrades       Trade[]           @relation("trade_buy_order")
  sellTrades      Trade[]           @relation("trade_sell_order")
}

model Trade {
  id            String      @id @default(cuid())
  companyId     String
  buyerId       String
  sellerId      String
  buyOrderId    String?
  sellOrderId   String?
  quantity      Int
  unitPrice     Decimal     @db.Decimal(24, 8)
  grossAmount   Decimal     @db.Decimal(18, 2)
  buyFeeAmount  Decimal     @db.Decimal(18, 2)
  sellFeeAmount Decimal     @db.Decimal(18, 2)
  createdAt     DateTime    @default(now())
  company       Company     @relation(fields: [companyId], references: [id])
  buyer         User        @relation("trade_buyer", fields: [buyerId], references: [id])
  seller        User        @relation("trade_seller", fields: [sellerId], references: [id])
  buyOrder      MarketOrder? @relation("trade_buy_order", fields: [buyOrderId], references: [id])
  sellOrder     MarketOrder? @relation("trade_sell_order", fields: [sellOrderId], references: [id])
  feeDistributions FeeDistribution[]
  buybackExecution ProjectBuybackExecution?
}



model PlatformAccount {
  id                String   @id @default(cuid())
  balance           Decimal  @default(0) @db.Decimal(18, 2)
  totalReceivedFees Decimal  @default(0) @db.Decimal(18, 2)
  totalWithdrawn    Decimal  @default(0) @db.Decimal(18, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model CompanyRevenueAccount {
  id                String   @id @default(cuid())
  companyId         String   @unique
  balance           Decimal  @default(0) @db.Decimal(18, 2)
  totalReceivedFees Decimal  @default(0) @db.Decimal(18, 2)
  totalWithdrawn    Decimal  @default(0) @db.Decimal(18, 2)
  totalUsedForBoost Decimal  @default(0) @db.Decimal(18, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  company           Company  @relation(fields: [companyId], references: [id])
}

model CompanyBoostAccount {
  id               String   @id @default(cuid())
  companyId        String   @unique
  rpcBalance       Decimal  @default(0) @db.Decimal(18, 2)
  totalInjectedRpc Decimal  @default(0) @db.Decimal(18, 2)
  totalUsedRpc     Decimal  @default(0) @db.Decimal(18, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  company          Company  @relation(fields: [companyId], references: [id])
}

model CompanyBoostInjection {
  id              String            @id @default(cuid())
  companyId       String
  userId          String?
  source          CompanyBoostSource
  amountRpc       Decimal           @db.Decimal(18, 2)
  priceBefore     Decimal           @db.Decimal(24, 8)
  priceAfter      Decimal           @db.Decimal(24, 8)
  marketCapBefore Decimal           @db.Decimal(18, 2)
  marketCapAfter  Decimal           @db.Decimal(18, 2)
  reason          String
  createdAt       DateTime          @default(now())
  company         Company           @relation(fields: [companyId], references: [id])
  user            User?             @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([userId])
  @@index([source])
  @@index([createdAt])
}

model FeeDistribution {
  id                   String        @id @default(cuid())
  companyId            String
  tradeId              String?
  operationId          String?
  payerUserId          String?
  sourceType           FeeSourceType
  totalFeeAmount       Decimal       @db.Decimal(18, 2)
  platformAmount       Decimal       @db.Decimal(18, 2)
  companyAmount        Decimal       @db.Decimal(18, 2)
  platformSharePercent Decimal       @db.Decimal(5, 2)
  companySharePercent  Decimal       @db.Decimal(5, 2)
  createdAt            DateTime      @default(now())
  company              Company       @relation(fields: [companyId], references: [id])
  trade                Trade?        @relation(fields: [tradeId], references: [id])
  operation            CompanyOperation? @relation(fields: [operationId], references: [id])
  payerUser            User?         @relation("fee_distribution_payer", fields: [payerUserId], references: [id])

  @@index([companyId, createdAt])
  @@index([tradeId])
  @@index([operationId])
  @@index([payerUserId])
}

model CoinIssuance {
  id            String   @id @default(cuid())
  createdById   String
  amount        Decimal  @db.Decimal(18, 2)
  reason        String
  destination   String
  previousValue Decimal  @db.Decimal(18, 2)
  newValue      Decimal  @db.Decimal(18, 2)
  createdAt     DateTime @default(now())
}

model WithdrawalRequest {
  id           String           @id @default(cuid())
  code         String           @unique
  userId       String
  user         User             @relation("withdrawal_request_user", fields: [userId], references: [id])
  amount       Decimal          @db.Decimal(18, 2)
  status       WithdrawalStatus @default(PENDING)
  userNote     String?
  adminNote    String?
  requestedAt  DateTime         @default(now())
  processingAt DateTime?
  completedAt  DateTime?
  rejectedAt   DateTime?
  canceledAt   DateTime?
  reviewedById String?
  reviewedBy   User?            @relation("withdrawal_request_reviewer", fields: [reviewedById], references: [id])
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([userId])
  @@index([status])
  @@index([code])
  @@index([createdAt])
}

model CoinTransfer {
  id            String       @id @default(cuid())
  type          TransferType
  senderId      String?
  receiverId    String?
  amount        Decimal      @db.Decimal(18, 2)
  reason        String
  previousValue Decimal      @db.Decimal(18, 2)
  newValue      Decimal      @db.Decimal(18, 2)
  createdAt     DateTime     @default(now())
  sender        User?        @relation("transfer_sender", fields: [senderId], references: [id])
  receiver      User?        @relation("transfer_receiver", fields: [receiverId], references: [id])
}

model Transaction {
  id          String   @id @default(cuid())
  walletId    String
  type        String
  amount      Decimal  @db.Decimal(18, 2)
  description String
  createdAt   DateTime @default(now())
}

model AdminLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entity     String
  previous   String?
  current    String?
  reason     String?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])
}


model RpcMarketState {
  id              String   @id @default(cuid())
  currentPrice    Decimal  @default(1) @db.Decimal(24, 8)
  fiatReserve     Decimal  @default(1000000) @db.Decimal(18, 2)
  rpcReserve      Decimal  @default(1000000) @db.Decimal(18, 2)
  totalFiatVolume Decimal  @default(0) @db.Decimal(18, 2)
  totalRpcVolume  Decimal  @default(0) @db.Decimal(18, 2)
  totalBuys       Int      @default(0)
  totalSells      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}


model RpcLimitOrder {
  id               String              @id @default(cuid())
  userId           String
  user             User                @relation(fields: [userId], references: [id])
  side             RpcExchangeSide
  status           RpcLimitOrderStatus @default(OPEN)
  fiatAmount       Decimal?            @db.Decimal(18, 2)
  rpcAmount        Decimal?            @db.Decimal(18, 2)
  limitPrice       Decimal             @db.Decimal(24, 8)
  lockedFiatAmount Decimal             @default(0) @db.Decimal(18, 2)
  lockedRpcAmount  Decimal             @default(0) @db.Decimal(18, 2)
  filledFiatAmount Decimal             @default(0) @db.Decimal(18, 2)
  filledRpcAmount  Decimal             @default(0) @db.Decimal(18, 2)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  executedAt       DateTime?
  canceledAt       DateTime?
  rejectedAt       DateTime?

  @@index([userId])
  @@index([side])
  @@index([status])
  @@index([limitPrice])
  @@index([createdAt])
}

model RpcExchangeTrade {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  side        RpcExchangeSide
  fiatAmount  Decimal         @db.Decimal(18, 2)
  rpcAmount   Decimal         @db.Decimal(18, 2)
  unitPrice   Decimal         @db.Decimal(24, 8)
  priceBefore Decimal         @db.Decimal(24, 8)
  priceAfter  Decimal         @db.Decimal(24, 8)
  createdAt   DateTime        @default(now())

  @@index([userId])
  @@index([createdAt])
}


model SystemModeConfig {
  id                 String   @id
  mode               String   @default("NORMAL")
  testTitle          String?
  testDescription    String?
  testEnabledAt      DateTime?
  testDisabledAt     DateTime?
  testDisabledReason String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model TestModeWallet {
  id          String   @id @default(cuid())
  userId      String   @unique
  fiatBalance Decimal  @default(10000.00) @db.Decimal(18, 2)
  rpcBalance  Decimal  @default(0.00) @db.Decimal(18, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}

model TestModeMarketState {
  id              String   @id
  currentPrice    Decimal  @default(1.00000000) @db.Decimal(24, 8)
  fiatReserve     Decimal  @default(1000000.00) @db.Decimal(18, 2)
  rpcReserve      Decimal  @default(1000000.00) @db.Decimal(18, 2)
  totalFiatVolume Decimal  @default(0) @db.Decimal(18, 2)
  totalRpcVolume  Decimal  @default(0) @db.Decimal(18, 2)
  totalBuys       Int      @default(0)
  totalSells      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TestModeTrade {
  id          String   @id @default(cuid())
  userId      String
  side        String
  fiatAmount  Decimal  @db.Decimal(18, 2)
  rpcAmount   Decimal  @db.Decimal(18, 2)
  unitPrice   Decimal  @db.Decimal(24, 8)
  priceBefore Decimal  @db.Decimal(24, 8)
  priceAfter  Decimal  @db.Decimal(24, 8)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model TestModeReport {
  id           String   @id @default(cuid())
  userId       String
  type         String
  location     String
  description  String
  status       String   @default("OPEN")
  userSnapshot String?
  adminNote    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])
}


model CompanyCapitalFlowEntry {
  id                       String                @id @default(cuid())
  companyId                String
  actorUserId              String
  type                     CompanyCapitalFlowType
  source                   CompanyCapitalFlowSource
  amountRpc                Decimal               @db.Decimal(18, 2)
  previousWalletRpcBalance Decimal               @db.Decimal(18, 2)
  newWalletRpcBalance      Decimal               @db.Decimal(18, 2)
  previousProjectBalance   Decimal               @db.Decimal(18, 2)
  newProjectBalance        Decimal               @db.Decimal(18, 2)
  reason                   String
  metadata                 String?
  createdAt                DateTime              @default(now())
  company                  Company               @relation(fields: [companyId], references: [id])
  actorUser                User                  @relation(fields: [actorUserId], references: [id])

  @@index([companyId])
  @@index([actorUserId])
  @@index([type])
  @@index([source])
  @@index([createdAt])
}


model ProjectBuybackProgram {
  id               String              @id @default(cuid())
  companyId        String
  createdByUserId  String
  status           ProjectBuybackStatus @default(ACTIVE)
  budgetRpc        Decimal             @db.Decimal(18, 2)
  spentRpc         Decimal             @default(0) @db.Decimal(18, 2)
  remainingRpc     Decimal             @db.Decimal(18, 2)
  maxPricePerShare Decimal             @db.Decimal(24, 8)
  targetShares     Int
  purchasedShares  Int                 @default(0)
  reason           String
  expiresAt        DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  canceledAt       DateTime?
  completedAt      DateTime?
  company          Company             @relation(fields: [companyId], references: [id])
  createdBy        User                @relation(fields: [createdByUserId], references: [id])
  executions       ProjectBuybackExecution[]
  reserveEntries   ProjectTokenReserveEntry[]

  @@index([companyId, status])
  @@index([createdByUserId])
}

model ProjectBuybackExecution {
  id             String   @id @default(cuid())
  programId      String
  companyId      String
  sellerUserId   String
  tradeId        String
  quantity       Int
  unitPrice      Decimal  @db.Decimal(24, 8)
  grossAmountRpc Decimal  @db.Decimal(18, 2)
  feeAmountRpc   Decimal  @default(0) @db.Decimal(18, 2)
  totalAmountRpc Decimal  @db.Decimal(18, 2)
  createdAt      DateTime @default(now())
  program        ProjectBuybackProgram @relation(fields: [programId], references: [id])
  company        Company  @relation(fields: [companyId], references: [id])
  seller         User     @relation(fields: [sellerUserId], references: [id])
  trade          Trade    @relation(fields: [tradeId], references: [id])
  reserveEntries ProjectTokenReserveEntry[]

  @@unique([tradeId])
  @@index([programId])
  @@index([companyId])
}

model ProjectTokenReserve {
  id           String   @id @default(cuid())
  companyId    String   @unique
  shares       Int      @default(0)
  totalCostRpc Decimal  @default(0) @db.Decimal(18, 2)
  policy       ProjectTokenReservePolicy @default(HOLD_LOCKED)
  locked       Boolean  @default(true)
  notes        String?
  lastAuditAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  company      Company  @relation(fields: [companyId], references: [id])
  entries      ProjectTokenReserveEntry[] @relation("reserve_entry_bucket")
}

model ProjectTokenReserveEntry {
  id             String   @id @default(cuid())
  companyId      String
  programId      String
  executionId    String
  type           String
  shares         Int
  unitPrice      Decimal  @db.Decimal(24, 8)
  totalCostRpc   Decimal  @db.Decimal(18, 2)
  reason         String
  createdAt      DateTime @default(now())
  company        Company  @relation("reserve_entry_company", fields: [companyId], references: [id], map: "fk_reserve_entry_company")
  program        ProjectBuybackProgram @relation(fields: [programId], references: [id])
  execution      ProjectBuybackExecution @relation(fields: [executionId], references: [id])
  reserve        ProjectTokenReserve @relation("reserve_entry_bucket", fields: [companyId], references: [companyId], map: "fk_reserve_entry_bucket")

  @@index([companyId])
  @@index([programId])
}


model ProjectHolderDistributionProgram {
  id                   String @id @default(cuid())
  companyId            String
  createdByUserId      String
  status               ProjectHolderDistributionStatus @default(READY)
  budgetRpc            Decimal @db.Decimal(18,2)
  distributedRpc       Decimal @default(0) @db.Decimal(18,2)
  refundedRpc          Decimal @default(0) @db.Decimal(18,2)
  eligibleShares       Int
  eligibleHoldersCount Int
  reason               String
  excludeFounder       Boolean @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  executedAt           DateTime?
  canceledAt           DateTime?
  company              Company @relation(fields:[companyId], references:[id])
  createdBy            User @relation(fields:[createdByUserId], references:[id])
  snapshots            ProjectHolderDistributionSnapshot[]
  payments             ProjectHolderDistributionPayment[]

  @@index([companyId, status])
  @@index([createdByUserId])
}

model ProjectHolderDistributionSnapshot {
  id                  String @id @default(cuid())
  programId           String
  companyId           String
  userId              String
  shares              Int
  sharePercent        Decimal @db.Decimal(24,8)
  calculatedAmountRpc Decimal @db.Decimal(18,2)
  paidAmountRpc       Decimal @default(0) @db.Decimal(18,2)
  status              ProjectHolderDistributionSnapshotStatus @default(PENDING)
  createdAt           DateTime @default(now())
  paidAt              DateTime?
  program             ProjectHolderDistributionProgram @relation(fields:[programId], references:[id])
  company             Company @relation(fields:[companyId], references:[id])
  user                User @relation(fields:[userId], references:[id])
  payments            ProjectHolderDistributionPayment[]

  @@index([programId])
  @@index([companyId])
  @@index([userId])
}

model ProjectHolderDistributionPayment {
  id            String @id @default(cuid())
  programId     String
  snapshotId    String
  companyId     String
  userId        String
  walletId      String
  transactionId String @unique
  amountRpc     Decimal @db.Decimal(18,2)
  createdAt     DateTime @default(now())
  program       ProjectHolderDistributionProgram @relation(fields:[programId], references:[id])
  snapshot      ProjectHolderDistributionSnapshot @relation(fields:[snapshotId], references:[id])
  company       Company @relation(fields:[companyId], references:[id])
  user          User @relation(fields:[userId], references:[id])

  @@index([programId])
  @@index([snapshotId])
  @@index([companyId])
  @@index([userId])
}
